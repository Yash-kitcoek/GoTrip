<% layout("/layouts/boilerplate") %>

<div id="filters">
    <div class="filter <%= category === 'Trending' ? 'active-filter' : '' %>" onclick="location.href='/listings?category=Trending'">
       <div><i class="fa-solid fa-bed"></i></div>
       <p>Trending</p>
    </div>
    <div class="filter <%= category === 'Rooms' ? 'active-filter' : '' %>" onclick="location.href='/listings?category=Rooms'">
       <div><i class="fa-solid fa-fire"></i></div>
       <p>Rooms</p>
    </div>
    <div class="filter <%= category === 'Iconic cities' ? 'active-filter' : '' %>" onclick="location.href='/listings?category=Iconic cities'">
       <div><i class="fa-solid fa-mountain-city"></i></div>
       <p>Iconic cities</p>
    </div>
    <div class="filter <%= category === 'Mountains' ? 'active-filter' : '' %>" onclick="location.href='/listings?category=Mountains'">
       <div><i class="fa-solid fa-mountain"></i></div>
       <p>Mountains</p>
    </div>
    <div class="filter <%= category === 'Castles' ? 'active-filter' : '' %>" onclick="location.href='/listings?category=Castles'">
       <div><i class="fa-brands fa-fort-awesome"></i></div>
       <p>Castles</p>
    </div>
    <div class="filter <%= category === 'Arctic' ? 'active-filter' : '' %>" onclick="location.href='/listings?category=Arctic'">
       <div><i class="fa-solid fa-snowflake"></i></div>
       <p>Arctic</p>
    </div>
    <div class="filter <%= category === 'Camping' ? 'active-filter' : '' %>" onclick="location.href='/listings?category=Camping'">
       <div><i class="fa-solid fa-binoculars"></i></div>
       <p>Camping</p>
    </div>
    <div class="filter <%= category === 'farms' ? 'active-filter' : '' %>" onclick="location.href='/listings?category=farms'">
       <div><i class="fa-solid fa-cow"></i></div>
       <p>farms</p>
    </div>
    <div class="filter <%= category === 'domes' ? 'active-filter' : '' %>" onclick="location.href='/listings?category=domes'">
       <div><i class="fa-solid fa-landmark-dome"></i></div>
       <p>domes</p>
    </div>
    <div class="filter <%= category === 'Boats' ? 'active-filter' : '' %>" onclick="location.href='/listings?category=Boats'">
       <div><i class="fa-solid fa-ship"></i></div>
       <p>Boats</p>
    </div>

    <div class="tax-toggle ms-auto">
      <div class="form-check-reverse form-switch">
        <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
        <label class="form-check-label" for="switchCheckDefault">Display total after Taxes</label>
      </div>
    </div>
</div>

<form class="listing-filter-panel" action="/listings" method="GET">
  <% if (category) { %>
    <input type="hidden" name="category" value="<%= category %>">
  <% } %>
  <div>
    <label>Min price</label>
    <input type="number" name="minPrice" min="0" value="<%= filters.minPrice || '' %>" placeholder="1000">
  </div>
  <div>
    <label>Max price</label>
    <input type="number" name="maxPrice" min="0" value="<%= filters.maxPrice || '' %>" placeholder="8000">
  </div>
  <div>
    <label>Guests</label>
    <input type="number" name="guests" min="1" max="20" value="<%= filters.guests || '' %>" placeholder="2">
  </div>
  <label class="instant-filter">
    <input type="checkbox" name="instantBook" <%= filters.instantBook ? "checked" : "" %>>
    Instant book
  </label>
  <button class="btn btn-dark" type="submit">Apply</button>
  <a href="/listings" class="btn btn-outline-secondary">Reset</a>
</form>

<% if (allListings.length === 0) { %>
  <div class="empty-state">
    <i class="fa-regular fa-compass"></i>
    <h4>No stays match these filters</h4>
    <p>Try widening the price range or guest count.</p>
    <a href="/listings" class="btn btn-dark">Browse all stays</a>
  </div>
<% } %>

<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
<% for(let listing of allListings) { %>
    <a href="/listings/<%= listing._id %>" class="listing-link">
        <div class="card col listing-card">
            <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image" style="height: 20rem;">
            <div class="card-img-overlay"></div>
            <div class="card-body">
                <p class="card-text">
                <b><%= listing.title %></b> <br>
                <span class="listing-meta"><%= listing.location %> · <%= listing.maxGuests || 2 %> guests · <%= listing.bedrooms || 1 %> bedrooms</span><br>
                <span class="listing-price">&#8377; <%= listing.price.toLocaleString("en-IN") %></span> / night
                <% if (listing.instantBook) { %>
                  <span class="instant-pill">Instant</span>
                <% } %>
                <i class="tax-info"> &nbsp; &nbsp;+18% GST</i>
            </p>
            </div>
        </div>
    </a>
<% } %>
</div>

<script>
    let taxSwitch = document.getElementById("switchCheckDefault");
    taxSwitch.addEventListener("click", () => {
        let taxInfo = document.getElementsByClassName("tax-info");
        for (let info of taxInfo) {
            if (info.style.display === "none" || info.style.display === "") {
                info.style.display = "inline";
            } else {
                info.style.display = "none";
            }
        }
    });
</script>
