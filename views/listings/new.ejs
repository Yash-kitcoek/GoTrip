<% layout("/layouts/boilerplate") %>

  <div class="row mt-3">
    <div class="col-8 offset-2">
      <h3 class="mt-3 mb-2">Create a New Listing</h3>

      <form action="/listings" method="POST" novalidate class="needs-validation" enctype="multipart/form-data">
        <div class="mb-3">
          <label for="title" class="form-label">Title</label>
          <input name="listing[title]" type="text" class="form-control" placeholder="Add a catchy title" required>
          <div class="valid-feedback">Title looks good!</div>
        </div>

        <div class="mb-3">
          <label for="description" class="form-label">Description</label>
          <textarea name="listing[description]" class="form-control" required></textarea>
          <div class="invalid-feedback">Please enter a short description</div>
        </div>

        <div class="mb-3">
          <label for="image" class="form-label">Upload Listing Image</label>
          <input name="listing[image]" type="file" class="form-control" required>
        </div>

        <div class="row">
          <div class="mb-3 col-md-4">
            <label for="price" class="form-label">Price</label>
            <input name="listing[price]" placeholder="1200" class="form-control" required>
            <div class="invalid-feedback">Price should be valid</div>
          </div>
          <div class="mb-3 col-md-8">
            <label for="country" class="form-label">Country</label>
            <input name="listing[country]" placeholder="India" type="text" class="form-control" required>
            <div class="invalid-feedback">Country name should be valid</div>
          </div>
        </div>

        <div class="mb-3">
          <label for="location" class="form-label">Location</label>
          <input name="listing[location]" placeholder="Jaipur, Rajasthan" type="text" class="form-control" required>
          <div class="invalid-feedback">Location should be valid</div>
        </div>

        <div class="mb-3">
          <label for="category" class="form-label">Category</label>
          <select name="listing[category]" class="form-select" required>
            <option value="">-- Select a Category --</option>
            <option value="Trending">Trending</option>
            <option value="Rooms">Rooms</option>
            <option value="Iconic cities">Iconic cities</option>
            <option value="Mountains">Mountains</option>
            <option value="Castles">Castles</option>
            <option value="Arctic">Arctic</option>
            <option value="Camping">Camping</option>
            <option value="farms">farms</option>
            <option value="domes">domes</option>
            <option value="Boats">Boats</option>
          </select>
          <div class="invalid-feedback">Please select a category</div>
        </div>

        <div class="row">
          <div class="mb-3 col-md-3">
            <label class="form-label">Guests</label>
            <input name="listing[maxGuests]" type="number" min="1" max="20" value="2" class="form-control" required>
          </div>
          <div class="mb-3 col-md-3">
            <label class="form-label">Bedrooms</label>
            <input name="listing[bedrooms]" type="number" min="0" max="20" value="1" class="form-control" required>
          </div>
          <div class="mb-3 col-md-3">
            <label class="form-label">Beds</label>
            <input name="listing[beds]" type="number" min="1" max="30" value="1" class="form-control" required>
          </div>
          <div class="mb-3 col-md-3">
            <label class="form-label">Bathrooms</label>
            <input name="listing[bathrooms]" type="number" min="0" max="20" step="0.5" value="1" class="form-control" required>
          </div>
        </div>

        <div class="mb-3">
          <label class="form-label">Amenities</label>
          <div class="amenity-grid">
            <% const amenities = ["Wifi", "Kitchen", "Free parking", "Air conditioning", "Pool", "Workspace", "Pet friendly", "Washer"]; %>
            <% for (let amenity of amenities) { %>
              <label class="amenity-option">
                <input type="checkbox" name="listing[amenities][]" value="<%= amenity %>">
                <span><%= amenity %></span>
              </label>
            <% } %>
          </div>
        </div>

        <div class="row">
          <div class="mb-3 col-md-6">
            <label class="form-label">Check-in Time</label>
            <input name="listing[checkInTime]" type="time" class="form-control" value="14:00">
          </div>
          <div class="mb-3 col-md-6">
            <label class="form-label">Check-out Time</label>
            <input name="listing[checkOutTime]" type="time" class="form-control" value="11:00">
          </div>
        </div>

        <div class="row">
          <div class="mb-3 col-md-6">
            <label class="form-label">Cleaning Fee</label>
            <input name="listing[cleaningFee]" type="number" min="0" value="0" class="form-control">
          </div>
          <div class="mb-3 col-md-6">
            <label class="form-label">Service Fee</label>
            <input name="listing[serviceFee]" type="number" min="0" value="0" class="form-control">
          </div>
        </div>

        <div class="mb-3">
          <label class="form-label">House Rules</label>
          <textarea name="listing[houseRules]" class="form-control" rows="3" placeholder="Quiet hours, pets, smoking, parties..."></textarea>
        </div>

        <div class="form-check form-switch mb-3">
          <input class="form-check-input" type="checkbox" role="switch" id="instantBook" name="listing[instantBook]">
          <label class="form-check-label" for="instantBook">Allow instant booking</label>
        </div>

        <button class="btn btn-dark my-3 add-btn">Add</button>
      </form>
    </div>
  </div>
