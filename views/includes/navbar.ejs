<style>
  .search-btn {
    background-color: #fe424d;
    color: #fff;
    border-radius: 25px;
    padding: 0 1.2rem;
    white-space: nowrap;
  }
  .search-btn:hover { background-color: #e0333e; color: #fff; }
  .search-inp {
    border-radius: 25px;
    padding: 0.45rem 1.2rem;
    font-size: 0.85rem;
    min-width: 180px;
  }
  .nav-auth-btn {
    border: 1.5px solid #222;
    border-radius: 25px;
    padding: 0.35rem 1rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: #222;
    text-decoration: none;
    white-space: nowrap;
    transition: all 0.2s;
  }
  .nav-auth-btn:hover { background: #222; color: #fff; }
  .nav-auth-btn.signup {
    background: #fe424d;
    border-color: #fe424d;
    color: #fff;
  }
  .nav-auth-btn.signup:hover { background: #e0333e; border-color: #e0333e; }
  .welcome-text { font-size: 0.85rem; color: #666; white-space: nowrap; }
</style>

<nav class="navbar navbar-expand-md navbar-light bg-white border-bottom sticky-top">
  <div class="container-fluid px-3">

    <!-- Brand -->
    <a class="navbar-brand fw-bold" href="/listings">
      <i class="fa-regular fa-compass text-danger"></i> GoTrip
    </a>

    <!-- Toggler -->
    <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse"
      data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="mainNav">

      <!-- Left: Explore -->
      <ul class="navbar-nav me-2">
        <li class="nav-item">
          <a class="nav-link" href="/listings">Explore</a>
        </li>
      </ul>

      <!-- Center: Search -->
      <form class="d-flex mx-auto my-2 my-md-0" role="search" action="/listings/search" method="GET">
        <input class="form-control me-2 search-inp" type="search" name="q" placeholder="Search destination" />
        <button class="btn search-btn" type="submit">
          <i class="fa-solid fa-magnifying-glass me-1"></i> Search
        </button>
      </form>

      <!-- Right: Auth -->
      <ul class="navbar-nav ms-2 d-flex flex-row align-items-center gap-2">
        <% if (!currUser) { %>
          <li class="nav-item">
            <a class="nav-link" href="/listings/new" style="white-space:nowrap; font-size:0.85rem;">Airbnb your home</a>
          </li>
          <li class="nav-item">
            <a href="/login" class="nav-auth-btn">Log in</a>
          </li>
          <li class="nav-item">
            <a href="/signup" class="nav-auth-btn signup">Sign up</a>
          </li>
        <% } else { %>
          <li class="nav-item">
            <a class="nav-link" href="/listings/new" style="white-space:nowrap; font-size:0.85rem;">Airbnb your home</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/wishlist" title="Wishlist">
              <i class="fa-regular fa-heart"></i>
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/bookings/my" title="My Trips">
              <i class="fa-solid fa-calendar-check"></i>
            </a>
          </li>
          <li class="nav-item welcome-text d-none d-lg-block">
            Hi, <strong><%= currUser.username %></strong>
          </li>
          <li class="nav-item">
            <a href="/logout" class="nav-auth-btn">Log out</a>
          </li>
        <% } %>
      </ul>

    </div>
  </div>
</nav>

