<% layout("/layouts/boilerplate") %>

<style>
  .bookings-header {
    background: linear-gradient(135deg, #fe424d 0%, #ff6b6b 100%);
    color: white;
    padding: 2.5rem 2rem;
    border-radius: 16px;
    margin-bottom: 2rem;
  }
  .booking-card {
    border: 1px solid #e8e8e8;
    border-radius: 16px;
    overflow: hidden;
    transition: box-shadow 0.2s ease;
    margin-bottom: 1.5rem;
  }
  .booking-card:hover {
    box-shadow: 0 8px 30px rgba(0,0,0,0.12);
  }
  .booking-img {
    width: 180px;
    min-height: 140px;
    object-fit: cover;
    flex-shrink: 0;
  }
  .booking-body {
    padding: 1.25rem 1.5rem;
    flex: 1;
  }
  .booking-dates {
    background: #f7f7f7;
    border-radius: 10px;
    padding: 0.75rem 1rem;
    font-size: 0.88rem;
    display: flex;
    gap: 1.5rem;
    margin: 0.75rem 0;
  }
  .badge-confirmed { background-color: #d4edda; color: #155724; }
  .badge-cancelled { background-color: #f8d7da; color: #721c24; }
  .badge-pending   { background-color: #fff3cd; color: #856404; }
  .status-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .price-tag {
    font-size: 1.3rem;
    font-weight: 700;
    color: #fe424d;
  }
  .empty-state {
    text-align: center;
    padding: 5rem 1rem;
    color: #888;
  }
  .empty-state i { font-size: 4rem; margin-bottom: 1rem; color: #ddd; }
  @media (max-width: 576px) {
    .booking-img { width: 100%; height: 180px; }
    .booking-card .d-flex { flex-direction: column; }
  }
</style>

<div class="bookings-header">
  <h2 class="mb-1"><i class="fa-solid fa-calendar-check me-2"></i>My Trips</h2>
  <p class="mb-0 opacity-75">Manage your upcoming and past bookings</p>
</div>

<% if (bookings.length === 0) { %>
  <div class="empty-state">
    <i class="fa-solid fa-suitcase-rolling d-block"></i>
    <h4>No trips yet!</h4>
    <p>You haven't made any bookings. Start exploring and book your first stay.</p>
    <a href="/listings" class="btn btn-dark mt-2">Explore Listings</a>
  </div>
<% } else { %>

  <%
    const upcoming = bookings.filter(b => b.status !== 'cancelled' && new Date(b.checkIn) >= new Date());
    const past = bookings.filter(b => b.status !== 'cancelled' && new Date(b.checkIn) < new Date());
    const cancelled = bookings.filter(b => b.status === 'cancelled');
  %>

  <% if (upcoming.length > 0) { %>
    <h5 class="fw-bold mb-3 text-muted">Upcoming Trips</h5>
    <% for (let booking of upcoming) { %>
      <%- include('./booking_card', { booking }) %>
    <% } %>
  <% } %>

  <% if (past.length > 0) { %>
    <h5 class="fw-bold mb-3 mt-4 text-muted">Past Trips</h5>
    <% for (let booking of past) { %>
      <%- include('./booking_card', { booking }) %>
    <% } %>
  <% } %>

  <% if (cancelled.length > 0) { %>
    <h5 class="fw-bold mb-3 mt-4 text-muted">Cancelled</h5>
    <% for (let booking of cancelled) { %>
      <%- include('./booking_card', { booking }) %>
    <% } %>
  <% } %>

<% } %>

